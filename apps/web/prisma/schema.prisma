// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════ ENUMS ═══════════
enum TravelMode {
  DRIVE
  TRANSIT
  WALK
  BICYCLE
}

enum FuelType {
  V93       
  V95       
  V97       
  diesel
  electrico
  hibrido
  gas_licuado
}

// ═══════════ USUARIOS ═══════════
model User {
  id               String           @id @default(uuid())
  email            String           @unique
  name             String?
  googleId         String?          @unique @map("google_id")
  avatarUrl        String?          @map("avatar_url")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  
  preferences      UserPreference?
  budgets          Budget[]
  carCandidates    CarCandidate[]
  commutes         Commute[]
  comparisons      Comparison[]

  @@map("users")
}

// ═══════════ PREFERENCIAS ═══════════
model UserPreference {
  userId                String   @id @map("user_id")
  defaultOriginAddress  String?  @map("default_origin_address")
  defaultOriginLat      Decimal? @db.Decimal(10, 7) @map("default_origin_lat")
  defaultOriginLng      Decimal? @db.Decimal(10, 7) @map("default_origin_lng")
  workDaysPerWeek       Int      @default(5) @map("work_days_per_week")
  weeksPerYear          Int      @default(48) @map("weeks_per_year")
  fuelPriceMarginPct    Decimal? @default(5.00) @db.Decimal(5, 2) @map("fuel_price_margin_pct")
  hourlyTimeValue       Decimal? @db.Decimal(10, 2) @map("hourly_time_value")
  currency              String   @default("CLP")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  
  user                  User     @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}

// ═══════════ PRESUPUESTO ═══════════
model Budget {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  sourceFile        String?  @map("source_file")
  processedAt       DateTime?@map("processed_at")
  monthlyIncome     Decimal? @db.Decimal(12, 2) @map("monthly_income")
  monthlyExpenses   Decimal? @db.Decimal(12, 2) @map("monthly_expenses")
  monthlySavings    Decimal? @db.Decimal(12, 2) @map("monthly_savings")
  categoryBreakdown Json?    @map("category_breakdown") // Usa Json en lugar de JsonB en Prisma
  rawRows           Json?    @map("raw_rows")
  createdAt         DateTime @default(now()) @map("created_at")
  
  user              User     @relation(fields: [userId], references: [id])

  @@map("budgets")
}

// ═══════════ CANDIDATOS A AUTO ═══════════
model CarCandidate {
  id                      String   @id @default(uuid())
  userId                  String   @map("user_id")
  name                    String
  sourceUrl               String?  @map("source_url")
  sourcePlatform          String?  @map("source_platform")
  purchasePrice           Decimal  @db.Decimal(12, 2) @map("purchase_price")
  year                    Int
  fuelType                FuelType @map("fuel_type")
  fuelEfficiencyCity      Decimal? @db.Decimal(6, 2) @map("fuel_efficiency_city")
  fuelEfficiencyHighway   Decimal? @db.Decimal(6, 2) @map("fuel_efficiency_highway")
  engineDisplacementCc    Int?     @map("engine_displacement_cc")
  transmission            String?
  bodyType                String?  @map("body_type")
  isNew                   Boolean  @default(false) @map("is_new")
  tasacionFiscal          Decimal? @db.Decimal(12, 2) @map("tasacion_fiscal")
  permisoCirculacionYr    Decimal? @db.Decimal(10, 2) @map("permiso_circulacion_yr")
  seguroAnualEstimated    Decimal? @db.Decimal(10, 2) @map("seguro_anual_estimated")
  mantenimientoAnualEst   Decimal? @db.Decimal(10, 2) @map("mantenimiento_anual_est")
  createdAt               DateTime @default(now()) @map("created_at")
  
  user                    User     @relation(fields: [userId], references: [id])

  @@map("car_candidates")
}

// ═══════════ TRAYECTOS ═══════════
model Commute {
  id                 String      @id @default(uuid())
  userId             String      @map("user_id")
  name               String
  originAddress      String      @map("origin_address")
  originLat          Decimal?    @db.Decimal(10, 7) @map("origin_lat")
  originLng          Decimal?    @db.Decimal(10, 7) @map("origin_lng")
  destinationAddress String      @map("destination_address")
  destinationLat     Decimal?    @db.Decimal(10, 7) @map("destination_lat")
  destinationLng     Decimal?    @db.Decimal(10, 7) @map("destination_lng")
  frequencyPerWeek   Int         @default(5) @map("frequency_per_week")
  isRequired         Boolean     @default(true) @map("is_required")
  createdAt          DateTime    @default(now()) @map("created_at")
  
  user               User        @relation(fields: [userId], references: [id])
  routeCaches        RouteCache[]

  @@map("commutes")
}

// ═══════════ CACHE DE RUTAS ═══════════
model RouteCache {
  id                   String     @id @default(uuid())
  commuteId            String     @map("commute_id")
  travelMode          TravelMode @map("travel_mode")
  fetchedAt            DateTime   @default(now()) @map("fetched_at")
  distanceMeters       Int        @map("distance_meters")
  durationSeconds      Int        @map("duration_seconds")
  durationNoTrafficSec Int?       @map("duration_no_traffic_sec")
  tollCostClp          Decimal?   @default(0) @db.Decimal(10, 2) @map("toll_cost_clp")
  trafficCondition     String?    @map("traffic_condition")
  routePolyline        String?    @map("route_polyline")
  rawResponse          Json?      @map("raw_response")
  expiresAt            DateTime   @map("expires_at")
  
  commute              Commute    @relation(fields: [commuteId], references: [id])

  @@unique([commuteId, travelMode, fetchedAt])
  @@index([commuteId, travelMode, fetchedAt(sort: Desc)])
  @@map("route_cache")
}

// ═══════════ PRECIOS COMBUSTIBLE (CNE) ═══════════
model FuelPrice {
  id            String   @id @default(uuid())
  fuelType      String   @map("fuel_type") // Enums no soportan números iniciales como '93', así que usamos String
  region        String?
  comuna        String?
  stationName   String?  @map("station_name")
  stationAddressString String? @map("station_address")
  pricePerLiter Decimal  @db.Decimal(8, 2) @map("price_per_liter")
  reportedDate  DateTime @db.Date @map("reported_date")
  scrapedAt     DateTime @default(now()) @map("scraped_at")
  isAggregate   Boolean  @default(false) @map("is_aggregate")

  @@index([fuelType, region, comuna, reportedDate(sort: Desc)])
  @@map("fuel_prices")
}

// ═══════════ TARIFAS TAG ═══════════
model TagTariff {
  id              String   @id @default(uuid())
  autopistaName   String   @map("autopista_name")
  tramoName       String   @map("tramo_name")
  vehicleCategory String   @default("liviano") @map("vehicle_category")
  horaPunta       Decimal? @db.Decimal(10, 2) @map("hora_punta")
  horaValle       Decimal? @db.Decimal(10, 2) @map("hora_valle")
  sabado          Decimal? @db.Decimal(10, 2)
  domingoFestivo  Decimal? @db.Decimal(10, 2) @map("domingo_festivo")
  effectiveFrom   DateTime @db.Date @map("effective_from")
  effectiveUntil  DateTime? @db.Date @map("effective_until") // Usar @db.Date si la BD guarda como DATE
  sourceUrl       String?  @map("source_url")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("tag_tariffs")
}

// ═══════════ COMPARACIONES ═══════════
model Comparison {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String?
  carCandidateIds String[] // En Postgres son UUID[]
  results         Json     @map("results")
  assumptions     Json     @map("assumptions")
  createdAt       DateTime @default(now()) @map("created_at")
  
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("comparisons")
}
